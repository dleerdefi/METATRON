# METATRON Configuration
# Copy to .env and modify as needed.

# LLM Backend (LM Studio)
METATRON_LLM_URL=http://localhost:1234
METATRON_MODEL=huihui-ai.huihui-qwen3.5-27b-abliterated
METATRON_MAX_TOKENS=8192
METATRON_TIMEOUT=600
METATRON_MAX_LOOPS=9

# Database (MariaDB)
METATRON_DB_HOST=localhost
METATRON_DB_USER=metatron
METATRON_DB_PASS=123
METATRON_DB_NAME=metatron
